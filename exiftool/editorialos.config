# Editorial OS custom XMP namespace for Photo Editor
# Persistent ExifTool config — checked in, never regenerated at runtime.
# Usage: exiftool -config exiftool/editorialos.config ...
%Image::ExifTool::UserDefined = (
    'Image::ExifTool::XMP::Main' => {
        editorialOS => {
            SubDirectory => {
                TagTable => 'Image::ExifTool::UserDefined::editorialOS',
            },
        },
    },
);

%Image::ExifTool::UserDefined::editorialOS = (
    GROUPS        => { 0 => 'XMP', 1 => 'XMP-editorialOS', 2 => 'Other' },
    NAMESPACE     => { 'editorialOS' => 'http://ns.editorialos.com/1.0/' },
    WRITABLE      => 'string',
    lookId         => {},
    shootId        => {},
    trackingId     => {},
    skus           => {},
    productTypes   => {},
    rights         => {},
    theme          => {},
    availableDates => {},
    productData    => {},
    notes          => {},
);

%Image::ExifTool::UserDefined::Options = (
    LargeFileSupport => 1,
);

1;  # end
